{
  "name": "modeltab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node tests/modeltab-static-regression.mjs",
    "test:worker": "node tests/modeltab.workspace-worker.mjs",
    "test:local-file": "node tests/modeltab.local-file-smoke.mjs",
    "test:visual": "playwright test tests/modeltab.visual.spec.mjs --reporter=line",
    "test:provider": "playwright test tests/modeltab.provider-smoke.spec.mjs --reporter=line",
    "test:live": "playwright test tests/modeltab.live.spec.mjs --reporter=line",
    "test:all": "npm test && npm run test:worker && npm run test:local-file && npm run test:visual && npm run test:provider"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
